                    {
                      type: 'scatter', mode: 'lines+markers',
                      name: `${factors.pressure.name} 상단(+)`,
                      x: interactXActual,
                      y: analysisResult?.interaction_data?.y_b_high || [88, 96],
                      line: { color: '#10B981', width: 2.5 },
                      marker: { size: 10, symbol: 'square' }
