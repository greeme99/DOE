                  className="flex-1 md:flex-none bg-green-50 text-green-700 border border-green-200 dark:bg-green-900 dark:border-green-800 dark:text-green-300 p-2 px-3 rounded-lg flex items-center justify-center gap-2 font-bold hover:bg-green-100 transition shadow-sm text-sm"
                >
                  <UploadCloud size={18} />
                  <span className="hidden sm:inline">결과 엑셀 업로드</span>
                </button>
              </div>
            </div>

            <div className="space-y-4">
              {verifyRuns.map((r, index) => (
                <div key={r.id} className="bg-theme-inset p-4 rounded-xl border border-theme flex flex-col md:flex-row md:items-center gap-4">
                  <div className="font-bold text-theme-main w-24 flex items-center gap-2">
                    Verify #{index + 1}
                    {r.yieldVal !== '' && <CheckCircle size={16} className="text-[--color-success]" />}
                  </div>
                  <div className="flex-1 flex gap-2 text-sm text-theme-main bg-theme-input p-2 rounded-lg border border-theme">
                    <div className="flex-1 text-center border-r border-theme">
                      <span className="text-xs opacity-60 block">{factors.temp.name}</span>
                      <span className="font-bold">{analysisResult?.golden_solution?.temp_level === 1 ? factors.temp.max : factors.temp.min}</span>
                    </div>
                    <div className="flex-1 text-center border-r border-theme">
                      <span className="text-xs opacity-60 block">{factors.pressure.name}</span>
                      <span className="font-bold">{analysisResult?.golden_solution?.pressure_level === 1 ? factors.pressure.max : factors.pressure.min}</span>
                    </div>
                    <div className="flex-1 text-center">
                      <span className="text-xs opacity-60 block">{factors.time.name}</span>
                      <span className="font-bold">{analysisResult?.golden_solution?.time_level === 1 ? factors.time.max : factors.time.min}</span>
                    </div>
                  </div>
                  <div className="flex items-center gap-2 w-full md:w-auto">
                    <input
                      type="number" placeholder="수율 입력" value={r.yieldVal}
                      onChange={(e) => updateVerifyYield(r.id, e.target.value)}
                      className="flex-1 md:w-32 p-3 border border-theme rounded-lg bg-theme-input text-right font-bold focus:ring-2 focus:ring-blue-500 outline-none transition text-theme-main shadow-inner"
                    />
                    <span className="text-theme-muted font-bold">%</span>
                  </div>
                </div>
              ))}
            </div>

            {/* Verify stats summary */}
            {verifyAvg && (
              <div className="mt-6 p-4 bg-green-50 dark:bg-green-900/20 rounded-lg border border-green-200 dark:border-green-800 flex items-center gap-4">
                <CheckCircle size={24} className="text-[--color-success] flex-shrink-0" />
                <div className="text-sm text-green-900 dark:text-green-200">
                  <strong>재현 실험 평균: {verifyAvg}%</strong> | 예측 수율: {predictedYield}% |
                  오차: {verifyError}%p
                  {parseFloat(verifyError) <= 2 ? ' ✓ 신뢰구간 내 진입' : ' — 오차 확인 필요'}
                </div>
              </div>
            )}

            <div className="mt-8 p-4 bg-blue-50 dark:bg-blue-900/30 rounded-lg flex items-start gap-4 border border-blue-100 dark:border-blue-800">
              <HelpCircle size={24} className="text-blue-500 flex-shrink-0 mt-1" />
              <div className="text-sm text-blue-900 dark:text-blue-200 leading-relaxed">
                <strong>검증 가이드:</strong> 3번의 재현 실험 평균이 예측 수율({predictedYield}%) 대비 95% 신뢰구간 내에 들어오면 해당 공정 조건을 최종 승인할 수 있습니다.
              </div>
            </div>
          </div>

          <div className="pt-4 flex justify-end">
            <button
              onClick={() => setCurrentTab(6)}
              disabled={verifyFilled < 3}
              className={`w-full md:w-auto px-10 py-4 font-bold text-lg rounded-[12px] shadow-md transition ${verifyFilled === 3 ? 'bg-[--color-success] text-white hover:bg-green-600 active:scale-95' : 'bg-gray-300 text-gray-500 cursor-not-allowed'}`}
            >
              {verifyFilled === 3 ? '최종 보고서 생성 (Report)' : '3회 재현 검증 입력 필요'}
            </button>
          </div>
        </div>
      );
    }

    // ────────────────────────────── TAB 6 ──────────────────────────────────────
    if (currentTab === 6) {
      const g6 = analysisResult?.golden_solution || {};
      const reportROI = `₩ ${roiAmountKRW}억`;

      return (
        <div className="p-4 md:p-8 space-y-6 max-w-5xl mx-auto pb-4">
          <div className="bg-theme-card border border-theme p-6 md:p-10 rounded-xl shadow-lg">

            {/* Header */}
            <div className="border-b border-gray-200 dark:border-gray-700 pb-6 mb-6">
              <div className="flex flex-col md:flex-row md:justify-between md:items-start gap-4">
                <div>
                  <h2 className="text-2xl md:text-3xl font-black text-theme-main mb-2">DOE 공정 최적화 결과 보고서</h2>
                  <p className="text-theme-muted font-medium">생성 일자: {new Date().toLocaleDateString('ko-KR')} | 대상 공정: {industry}</p>
                </div>
                <div className="bg-[--color-success] text-white px-5 py-2.5 rounded-lg font-black text-lg self-start">최종 승인 (Pass)</div>
              </div>
            </div>

            {/* Content */}
            <div className="grid grid-cols-1 md:grid-cols-2 gap-8 mb-10">
              <div className="space-y-8">
                <div>
                  <h3 className="text-lg font-bold text-theme-main mb-3 border-l-4 border-[--color-primary] pl-3">1. 핵심 진단 요약</h3>
                  <div className="bg-blue-50 dark:bg-blue-900/20 p-5 rounded-lg text-[15px] text-theme-main leading-relaxed border border-blue-100 dark:border-blue-800">
                    • 가장 중요한 관리 인자는 <strong>{Object.entries(analysisResult?.tvalues || {}).sort((a, b) => Math.abs(b[1]) - Math.abs(a[1]))[0]?.[0] || factors.temp.name}</strong>입니다.<br />
                    • 다중 반응 기반 수율 {predictedYield}% 달성을 위한 최적 조합이 확보되었습니다.
                  </div>
                </div>
                <div>
                  <h3 className="text-lg font-bold text-theme-main mb-3 border-l-4 border-amber-500 pl-3">2. 도출된 최적해 (Golden Solution)</h3>
                  <div className="bg-amber-50 dark:bg-amber-900/20 p-5 rounded-lg flex justify-between text-theme-main border border-amber-100 dark:border-amber-800">
                    <div className="text-center">
                      <div className="text-xs opacity-70 mb-1">{factors.temp.name}</div>
                      <div className="font-bold text-xl">{g6.temp_level === 1 ? factors.temp.max : factors.temp.min}</div>
                    </div>
                    <div className="text-center">
                      <div className="text-xs opacity-70 mb-1">{factors.pressure.name}</div>
                      <div className="font-bold text-xl">{g6.pressure_level === 1 ? factors.pressure.max : factors.pressure.min}</div>
                    </div>
                    <div className="text-center">
                      <div className="text-xs opacity-70 mb-1">{factors.time.name}</div>
                      <div className="font-bold text-xl">{g6.time_level === 1 ? factors.time.max : factors.time.min}</div>
                    </div>
                  </div>
                </div>
              </div>

              <div className="space-y-8">
                <div>
                  <h3 className="text-lg font-bold text-theme-main mb-3 border-l-4 border-[--color-success] pl-3">3. 현장 재현 검증 결과</h3>
                  <div className="bg-green-50 dark:bg-green-900/20 p-5 rounded-lg text-theme-main text-[15px] leading-relaxed border border-green-100 dark:border-green-800">
                    • AI 예측 수율: <strong>{predictedYield}%</strong><br />
                    • 3회 재현 평균: <strong>{verifyAvg ?? '-'}%</strong><br />
                    • 오차율: {verifyError ? `${verifyError}%p (신뢰구간 내 확인)` : '검증 데이터 입력 후 확인'}
                  </div>
                </div>
                <div>
                  <h3 className="text-lg font-bold text-theme-main mb-3 border-l-4 border-purple-500 pl-3">4. 비즈니스 임팩트 (ROI)</h3>
                  <div className="bg-purple-50 dark:bg-purple-900/20 p-5 rounded-lg text-center text-theme-main border border-purple-100 dark:border-purple-800">
                    <div className="text-sm opacity-80 mb-2 font-medium">연간 예상 손실비용 절감액</div>
                    <div className="font-black text-3xl text-purple-700 dark:text-purple-400">{reportROI}</div>
                    {analysisResult?.yield_gain > 0 && (
                      <div className="text-xs text-gray-500 mt-2">수율 {analysisResult.yield_gain.toFixed(1)}%p 개선 기반 산출</div>
                    )}
                  </div>
                </div>
              </div>
            </div>

            {/* Action Buttons */}
            <div className="flex flex-col sm:flex-row justify-center gap-4 pt-8 border-t border-gray-200 dark:border-gray-700 pb-2">
              <button onClick={() => alert('PDF 보고서가 생성되어 다운로드 되었습니다.')} className="flex flex-1 items-center justify-center gap-2 px-6 py-4 bg-white text-black border border-gray-300 rounded-xl font-bold hover:bg-gray-50 transition shadow-sm text-lg">
                <Download size={22} className="text-gray-700" /> PDF 다운로드
              </button>
              <button onClick={() => alert('보고서가 이메일로 전송되었습니다.')} className="flex flex-1 items-center justify-center gap-2 px-6 py-4 bg-theme-background border border-theme text-theme-main rounded-xl font-bold hover:opacity-80 transition shadow-sm text-lg">
                <Mail size={22} /> 이메일 공유
              </button>
              <button onClick={() => alert('공유 링크가 클립보드에 복사되었습니다.')} className="flex flex-1 items-center justify-center gap-2 px-6 py-4 bg-green-100 text-green-800 dark:bg-green-900/50 dark:text-green-300 rounded-xl font-bold border border-green-200 dark:border-green-800 hover:opacity-80 transition shadow-sm text-lg">
                <Share2 size={22} /> 메신저 공유
              </button>
            </div>
          </div>
        </div>
      );
    }

    return null;
  };

  // ─── Tab Config ───────────────────────────────────────────────────────────────

  const tabs = [
    { id: 1, label: '설계', icon: Settings },
    { id: 2, label: '입력', icon: PenTool },
    { id: 3, label: '분석', icon: BarChart2 },
    { id: 4, label: '최적화', icon: Zap },
    { id: 5, label: '검증', icon: CheckCircle },
    { id: 6, label: '보고서', icon: FileText }
  ];

  // ─── Main JSX ─────────────────────────────────────────────────────────────────

  return (
    <div className="min-h-screen flex flex-col md:flex-row bg-theme-main font-sans transition-colors duration-300">

      {/* Sidebar / Header */}
      <div className="md:w-64 md:flex-shrink-0 bg-[var(--color-sidebar-bg)] text-white shadow-xl flex flex-col z-20">
        <header className="p-4 md:p-6 sticky md:static top-0 bg-[var(--color-header-bg)] text-[var(--color-header-text)] shadow-md border-b border-black/5 md:border-none md:shadow-none flex items-center justify-between md:flex-col md:items-start md:gap-4 transition-colors duration-300">
          <div className="flex-1">
            <h1 className="text-lg md:text-2xl font-bold tracking-wider flex items-center gap-2 text-black md:text-[var(--color-header-text)]">
              <Zap size={24} className="text-yellow-500 md:text-yellow-400" fill="currentColor" />
              <span>DOE Auto</span>
            </h1>
            <p className="hidden md:block text-sm text-blue-200 opacity-90 mt-2">현장 밀착형 스마트 실험계획법</p>
          </div>
          <div className="flex items-center gap-3">
            <div className="md:w-full bg-[#152e6e] px-2 py-1.5 md:hidden rounded-lg text-xs font-bold border border-blue-800 text-white shrink-0">
              STEP {currentTab}/6
            </div>
            <div className="flex items-center bg-black/5 md:bg-black/20 rounded-lg p-1 shrink-0">
              <Monitor size={14} className="mx-1 opacity-60 hidden sm:block text-black md:text-white" />
              <select
                value={theme}
                onChange={(e) => setTheme(e.target.value)}
                className="bg-transparent text-xs font-medium outline-none cursor-pointer appearance-none px-1 text-black md:text-white"
              >
                <option value="light-gray-blue" className="text-black">Gray+Blue (기본)</option>
                <option value="white" className="text-black">White Theme</option>
                <option value="black" className="text-black">Dark Theme</option>
              </select>
            </div>
          </div>
        </header>

        {/* Desktop sidebar nav */}
        <nav className="hidden md:flex flex-col flex-1 p-4 gap-2 border-t border-black/10">
          <div className="text-xs font-bold text-gray-400 dark:text-blue-300 uppercase tracking-wider mb-2 ml-2">WorkFlow</div>
          {tabs.map(tab => {
            const Icon = tab.icon;
            const isActive = currentTab === tab.id;
            return (
              <button
                key={tab.id}
                onClick={() => setCurrentTab(tab.id)}
                className={`flex items-center gap-3 p-3 rounded-xl transition-all w-full text-left ${isActive ? 'sidebar-tab-active font-extrabold text-[1.125rem]' : 'sidebar-tab-idle font-medium text-[0.95rem]'}`}
              >
                <Icon size={isActive ? 22 : 20} strokeWidth={isActive ? 2.5 : 2} />
                <span>{tab.label}</span>
                {isActive && <div className="ml-auto w-2 h-2 rounded-full bg-[--color-success]"></div>}
              </button>
            );
          })}

          {/* ① 자동 저장 상태 표시 */}
          <div className="mt-auto pt-4 border-t border-white/10">
            {lastSaved ? (
              <div className="flex items-center gap-2 px-2 py-2 text-xs text-blue-300 opacity-70">
                <CheckCircle size={12} />
                <span>자동 저장 {lastSaved.toLocaleTimeString('ko-KR', { hour: '2-digit', minute: '2-digit', second: '2-digit' })}</span>
              </div>
            ) : runs.length > 0 ? (
              <div className="px-2 py-2 text-xs text-blue-300 opacity-50">저장 준비중...</div>
            ) : null}
            <button
              onClick={handleReset}
              className="w-full flex items-center gap-2 px-3 py-2 rounded-lg text-xs text-red-300 hover:bg-red-900/30 transition mt-1"
            >
              <RefreshCw size={12} />
              데이터 초기화
            </button>
          </div>
        </nav>
      </div>

      {/* Main Content */}
      <main className="flex-1 overflow-y-auto pb-24 md:pb-0 h-screen relative bg-theme-main transition-colors duration-300">
        <div className="hidden md:block absolute top-0 right-0 p-6 opacity-5 pointer-events-none text-theme-main">
          <Settings size={200} />
        </div>
        <div className="relative z-10 w-full">
          {renderTabContent()}
        </div>
      </main>

      {/* Mobile Bottom Tab Bar */}
      <nav className="md:hidden bg-theme-card border-t border-theme fixed bottom-0 w-full flex justify-between px-1 py-1.5 pb-safe shadow-[0_-4px_15px_rgba(0,0,0,0.05)] z-30 transition-colors duration-300">
        {tabs.map(tab => {
          const Icon = tab.icon;
          const isActive = currentTab === tab.id;
          return (
            <button
              key={tab.id}
              onClick={() => setCurrentTab(tab.id)}
              className={`flex-1 flex flex-col items-center justify-center p-2 rounded-xl transition-all ${isActive ? 'text-blue-600 bg-blue-50 dark:bg-blue-900/30 font-bold' : 'text-sky-400 hover:text-sky-600 font-medium'}`}
            >
              <Icon size={22} strokeWidth={isActive ? 2.5 : 2} className={isActive ? 'mb-1' : 'mb-1 opacity-70'} />
              <span className="text-[10px]">{tab.label}</span>
            </button>
          );
        })}
      </nav>

      {/* ① 숨김 파일 인풋 (엑셀 업로드용) */}
      <input
        ref={excelInputRef}
        type="file"
        accept=".xlsx,.xls"
        onChange={handleExcelUpload}
        style={{ display: 'none' }}
      />
      <input
        ref={verifyExcelInputRef}
        type="file"
        accept=".xlsx,.xls"
        onChange={handleVerifyExcelUpload}
        style={{ display: 'none' }}
      />
    </div>
  );
}
