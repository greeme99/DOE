                  layout={{
                    autosize: true, margin: { l: 40, r: 20, t: 10, b: 50 },
                    xaxis: { title: `${factors.temp.name} (${factors.temp.unit})` },
                    yaxis: { title: '예상 수율 (%)' },
                    legend: { orientation: 'h', y: -0.25, x: 0.5, xanchor: 'center' },
                    paper_bgcolor: 'transparent', plot_bgcolor: 'transparent'
                  }}
                  useResizeHandler style={{ width: '100%', height: '100%' }}
                  config={{ displayModeBar: false }}
                />
              </div>
            </div>

            {/* Chart 4: Normal Probability Plot ─────────────────── NEW */}
            <div className="bg-theme-card p-4 md:p-6 rounded-xl shadow-sm border border-theme">
              <h3 className="text-base md:text-lg font-bold text-theme-main mb-2 flex items-center gap-2">
                <Award size={20} className="text-[--color-primary]" />
                정규 확률도 (Normal Probability Plot)
              </h3>
              <p className="text-xs text-theme-muted mb-4">잔차가 직선에 가까울수록 모형 가정 성립</p>
              <div className="h-64 md:h-72 w-full relative">
                <Plot
                  data={[
                    {
                      type: 'scatter', mode: 'markers',
                      name: '잔차',
                      x: analysisResult?.norm_plot_x || [],
                      y: analysisResult?.norm_plot_y || [],
                      marker: { color: '#1E3A8A', size: 9, symbol: 'circle' }
                    },
                    {
                      type: 'scatter', mode: 'lines',
                      name: '기준선',
                      x: normRefLine.x,
                      y: normRefLine.y,
                      line: { color: '#EF4444', dash: 'dash', width: 1.5 }
                    }
                  ]}
                  layout={{
                    autosize: true, margin: { l: 50, r: 20, t: 10, b: 40 },
                    xaxis: { title: '이론적 분위수 (Normal Quantile)' },
                    yaxis: { title: '잔차 (Residual)' },
                    legend: { orientation: 'h', y: -0.25, x: 0.5, xanchor: 'center' },
                    paper_bgcolor: 'transparent', plot_bgcolor: 'transparent'
                  }}
                  useResizeHandler style={{ width: '100%', height: '100%' }}
                  config={{ displayModeBar: false }}
                />
              </div>
            </div>
          </div>

          {/* Chart 5: Cube Plot (full-width 3D) ──────────────────── NEW */}
          <div className="bg-theme-card p-4 md:p-6 rounded-xl shadow-sm border border-theme">
            <h3 className="text-base md:text-lg font-bold text-theme-main mb-2 flex items-center gap-2">
              <Target size={20} className="text-[--color-primary]" />
              큐브 플롯 (Cube Plot — 3D 회귀 예측 수율)
            </h3>
            <p className="text-xs text-theme-muted mb-4">8개 코너 조합의 예측 수율 — 드래그하여 회전 가능</p>
            <div className="h-80 md:h-96 w-full relative">
              <Plot
                data={[{
                  type: 'scatter3d', mode: 'markers+text',
                  x: cubeData.map(d => d.x),
                  y: cubeData.map(d => d.y),
                  z: cubeData.map(d => d.z),
                  text: cubeData.map(d => `${d.pred}%`),
                  textposition: 'top center',
                  hovertemplate: `${factors.temp.name}: %{x}<br>${factors.pressure.name}: %{y}<br>${factors.time.name}: %{z}<br>예측 수율: %{text}<extra></extra>`,
                  marker: {
                    size: 12,
                    color: cubeData.map(d => d.pred),
                    colorscale: 'RdYlGn',
                    showscale: true,
                    colorbar: { title: '수율(%)', thickness: 14, len: 0.7 },
                    line: { color: 'rgba(0,0,0,0.3)', width: 1 }
                  }
                }]}
                layout={{
                  autosize: true,
                  margin: { l: 0, r: 0, t: 20, b: 0 },
                  scene: {
                    xaxis: { title: `${factors.temp.name} (${factors.temp.unit})` },
                    yaxis: { title: `${factors.pressure.name} (${factors.pressure.unit})` },
                    zaxis: { title: `${factors.time.name} (${factors.time.unit})` },
                    camera: { eye: { x: 1.6, y: 1.6, z: 1.2 } }
                  },
                  paper_bgcolor: 'transparent'
                }}
                useResizeHandler style={{ width: '100%', height: '100%' }}
                config={{ displayModeBar: true, displaylogo: false }}
              />
            </div>
          </div>

          <div className="pt-4 flex justify-end">
            <button
              onClick={() => setCurrentTab(4)}
              className="w-full md:w-auto px-10 py-4 bg-[--color-success] text-white rounded-[12px] font-bold text-lg shadow-md hover:bg-green-600 transition active:scale-95"
            >
              최적해 도출하기 (Optimize)
            </button>
          </div>
        </div>
      );
    }

    // ────────────────────────────── TAB 4 ──────────────────────────────────────
    if (currentTab === 4) {
      const g = analysisResult ? analysisResult.golden_solution : { temp_level: 1, pressure_level: -1, time_level: 1 };
      const eq_str = analysisResult
        ? `Ŷ = ${analysisResult.intercept} + ${analysisResult.params['Temp']}(Temp) + ${analysisResult.params['Pressure']}(Press) + ${analysisResult.params['Time']}(Time)`
        : `Ŷ (예측 수율) = 45.28 + 0.35 × ${factors.temp.name} - 0.21 × ${factors.pressure.name} + ...`;

      return (
        <div className="p-4 md:p-8 space-y-8 max-w-7xl mx-auto pb-4">
          <div className="bg-gradient-to-br from-yellow-50 to-amber-100 border border-yellow-200 p-6 md:p-8 rounded-xl shadow-sm relative overflow-hidden">
            <div className="absolute right-0 top-0 opacity-10 transform translate-x-4 -translate-y-4"><Award size={160} /></div>
            <div className="relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-8">
              <div className="flex-1">
                <h2 className="text-xl md:text-2xl font-bold text-amber-600 mb-2 flex items-center gap-2">
                  <Award size={28} /> Golden Solution (AI 회귀 최적해)
                </h2>
                <p className="text-gray-700 md:text-lg mb-6">다중 반응 최적화(Desirability)를 통해 산출된 <strong>초고수율 달성 최적 조건</strong>입니다.</p>

                <div className="grid grid-cols-3 gap-3 md:gap-4">
                  {[
                    { label: factors.temp.name, unit: factors.temp.unit, val: g.temp_level === 1 ? factors.temp.max : factors.temp.min, level: g.temp_level },
                    { label: factors.pressure.name, unit: factors.pressure.unit, val: g.pressure_level === 1 ? factors.pressure.max : factors.pressure.min, level: g.pressure_level },
                    { label: factors.time.name, unit: factors.time.unit, val: g.time_level === 1 ? factors.time.max : factors.time.min, level: g.time_level }
                  ].map((item, idx) => (
                    <div key={idx} className="bg-white/80 p-4 rounded-xl text-center backdrop-blur-sm border border-yellow-300 shadow-sm">
                      <div className="text-xs md:text-sm text-gray-500 font-bold mb-1">{item.label}</div>
                      <div className="text-xl md:text-3xl font-black text-gray-800">
                        {item.val}<span className="text-sm md:text-base text-gray-500 ml-1">{item.unit}</span>
                      </div>
                      <div className={`text-[10px] mt-1 font-bold ${item.level === 1 ? 'text-green-600' : 'text-blue-600'}`}>
                        {item.level === 1 ? '+ 상단 조건' : '− 하단 조건'}
                      </div>
                    </div>
                  ))}
                </div>
              </div>

              {/* ③ 동적 ROI 카드 */}
              <div className="bg-white p-6 rounded-2xl shadow-lg border-2 border-yellow-400 w-full md:w-72 text-center transform hover:scale-105 transition">
                <div className="text-gray-500 font-bold mb-2">예상 불량 감소에 따른</div>
                <div className="text-xl font-black text-gray-800 mb-2">연간 비용 절감 (ROI)</div>
                <div className="text-4xl font-black text-[--color-success] mb-2 drop-shadow-sm">
                  ₩ {roiAmountKRW}억
                </div>
                <div className="text-xs text-gray-400 mb-1 bg-gray-100 rounded inline-block px-2 py-1">
                  예측 수율: <strong>{predictedYield}%</strong>
                </div>
                {analysisResult?.current_avg_yield && (
                  <div className="text-xs text-gray-400 mb-3">
                    현재 평균: {analysisResult.current_avg_yield.toFixed(1)}% (+{analysisResult.yield_gain.toFixed(1)}%p 개선)
                  </div>
                )}
                <button className="w-full py-2 bg-yellow-100 text-yellow-800 rounded font-bold text-sm hover:bg-yellow-200 transition">상세 근거 보기</button>
              </div>
            </div>
          </div>

          <div className="bg-theme-card p-6 border border-theme shadow-sm rounded-xl">
            <h3 className="text-lg font-bold text-theme-main mb-3 flex items-center gap-2">
              <TrendingUp size={20} className="text-[--color-primary]" /> 회귀 최적해 산출 수식 (FastAPI Statsmodels)
            </h3>
            <div className="bg-gray-50 dark:bg-gray-800 p-4 rounded-lg overflow-x-auto border border-gray-200 dark:border-gray-700">
              <code className="text-sm md:text-base text-blue-800 dark:text-blue-300 font-mono whitespace-nowrap">{eq_str}</code>
            </div>
            <p className="text-sm text-theme-muted mt-3">
              R-Sq = {analysisResult ? (analysisResult.r_squared * 100).toFixed(1) : '92.4'}% | 위 회귀 모델 기반으로 최적화 시뮬레이션 산출 결과
            </p>
          </div>

          <div className="pt-4 flex justify-end">
            <button
              onClick={() => setCurrentTab(5)}
              className="w-full md:w-auto flex items-center justify-center gap-2 px-10 py-4 bg-[--color-primary] text-white rounded-[12px] font-bold text-lg shadow-md hover:bg-blue-800 transition active:scale-95"
            >
              현장 재현 실험하러 가기 <ArrowRight size={20} />
            </button>
          </div>
        </div>
      );
    }

    // ────────────────────────────── TAB 5 ──────────────────────────────────────
    if (currentTab === 5) {
      return (
        <div className="p-4 md:p-8 space-y-6 max-w-7xl mx-auto pb-4">
          <div className="bg-theme-card border border-theme p-6 rounded-xl shadow-sm">
            <div className="flex flex-col md:flex-row md:items-center justify-between mb-6 gap-4">
              <div>
                <h2 className="text-xl md:text-2xl font-bold text-[--color-primary] mb-2 flex items-center gap-2">
                  <Target size={28} /> 재현 실험 (Confirmation Runs)
                </h2>
                <p className="text-theme-muted max-w-2xl">
                  최적해(Golden Solution) 조합으로 도출된 예측 수율(<strong>{predictedYield}%</strong>)이 현장에서도 유효한지 3회 재현 실험으로 검증합니다.
                </p>
