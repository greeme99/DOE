# ── DOE Auto Backend 환경변수 ──────────────────────────────────────────────
# 이 파일을 .env 로 복사하고 값을 채워주세요
# cp .env.example .env

# Supabase (supabase.com > Settings > API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# CORS — 프론트엔드 URL (쉼표 구분, 로컬은 * 그대로 사용)
ALLOWED_ORIGINS=*
# 배포 후 예시:
# ALLOWED_ORIGINS=https://doe-auto.netlify.app,http://localhost:5173
